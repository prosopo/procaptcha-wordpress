{
  "name": "@prosopo/procaptcha-wordpress",
  "version": "0.2.17",
  "author": "PROSOPO LIMITED <info@prosopo.io>",
  "license": "Apache-2.0",
  "private": false,
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "clean": "tsc --build --clean",
    "build": "tsc --build --verbose tsconfig.json",
    "build:cjs": "npx vite --config vite.cjs.config.ts build",
    "eslint": "npx eslint . --no-error-on-unmatched-pattern --ignore-path ../../.eslintignore",
    "eslint:fix": "npm run eslint -- --fix",
    "prettier": "npx prettier . --check --no-error-on-unmatched-pattern --ignore-path ../../.eslintignore",
    "prettier:fix": "npm run prettier -- --write",
    "lint": "npm run eslint && npm run prettier",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "test": "NODE_ENV=test vitest --run --coverage"
  },
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {

  },
  "devDependencies": {
    "@prosopo/config": "0.2.17",
    "@types/chai": "^4.3.5",
    "@vitest/coverage-v8": "^0.34.3",
    "chai": "^4.3.7",
    "tslib": "2.6.2",
    "typescript": "5.1.6",
    "vitest": "^0.34.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosopo/procaptcha-wordpress-integration.git"
  },
  "bugs": {
    "url": "https://github.com/prosopo/procaptcha-wordpress-integration/issues"
  },
  "homepage": "https://github.com/prosopo/procaptcha-wordpress-integration#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "description": "Procaptcha wordpress integration for forms and more.",
  "sideEffects": false
}
